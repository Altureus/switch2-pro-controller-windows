# Python build artifacts
__pycache__/
*.py[cod]
*.egg-info/

# runtime / transient
*.pid
*.log

# generated controller mapping is intentionally tracked (mapping_data.py),
# but local Dolphin captures / scratch files are not
*.pcapng
*.etl
scratch/

# PyInstaller .exe build artifacts (rebuild with build_exe.bat; the .exe ships
# as a GitHub release asset, not committed to git)
build/
dist/
*.spec

# stray local scratch (smoke-test output); never track
/so.txt
/se.txt
